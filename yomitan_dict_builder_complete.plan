## 8. CONTENT BUILDER (content_builder.rs)

```rust
use serde_json::json;
use crate::models::Character;

pub struct ContentBuilder {
    spoiler_level: u8,
}

impl ContentBuilder {
    pub fn new(spoiler_level: u8) -> Self {
        Self { spoiler_level }
    }

    /// Strip spoiler tags from text
    pub fn strip_spoilers(text: &str) -> String {
        let text = regex::Regex::new(r"\[spoiler\].*?\[/spoiler\]")
            .unwrap()
            .replace_all(text, "");
        regex::Regex::new(r"~!.*?!~")
            .unwrap()
            .replace_all(&text, "")
            .to_string()
    }

    /// Format physical stats line
    pub fn format_stats(&self, char: &Character) -> String {
        let mut parts = Vec::new();

        if let Some(sex) = &char.sex {
            parts.push(format!("{} {}", 
                if sex == "m" { "♂" } else { "♀" }, 
                if sex == "m" { "Male" } else { "Female" }
            ));
        }

        if let Some(age) = &char.age {
            parts.push(format!("{} years", age));
        }

        if let Some(height) = char.height {
            parts.push(format!("{}cm", height));
        }

        if let Some(weight) = char.weight {
            parts.push(format!("{}kg", weight));
        }

        if let Some(blood_type) = &char.blood_type {
            parts.push(format!("Blood Type {}", blood_type));
        }

        parts.join(" • ")
    }

    /// Build structured content for Yomitan
    pub fn build_content(&self, char: &Character, image_path: Option<&str>, game_title: &str) -> serde_json::Value {
        let mut content = vec![];

        // Japanese name
        content.push(json!({
            "tag": "div",
            "style": { "fontWeight": "bold", "fontSize": "1.2em" },
            "content": &char.name_original
        }));

        // Romanized name
        content.push(json!({
            "tag": "div",
            "style": { "fontStyle": "italic", "color": "#666", "marginBottom": "8px" },
            "content": &char.name
        }));

        // Image
        if let Some(path) = image_path {
            content.push(json!({
                "tag": "img",
                "path": path,
                "width": 80,
                "height": 100,
                "sizeUnits": "px",
                "collapsible": false,
                "collapsed": false,
                "background": false
            }));
        }

        // Game title
        content.push(json!({
            "tag": "div",
            "style": { "fontSize": "0.9em", "color": "#888", "marginTop": "4px" },
            "content": format!("From: {}", game_title)
        }));

        // Role badge
        let role_colors = match char.role.as_str() {
            "main" => "#4CAF50",
            "primary" => "#2196F3",
            "side" => "#FF9800",
            _ => "#9E9E9E",
        };

        let role_label = match char.role.as_str() {
            "main" => "Protagonist",
            "primary" => "Main Character",
            "side" => "Side Character",
            _ => "Minor Role",
        };

        content.push(json!({
            "tag": "span",
            "style": {
                "background": role_colors,
                "color": "white",
                "padding": "2px 6px",
                "borderRadius": "3px",
                "fontSize": "0.85em",
                "marginTop": "4px"
            },
            "content": role_label
        }));

        // Description and info (if spoiler level >= 1)
        if self.spoiler_level >= 1 {
            if let Some(desc) = &char.description {
                let display_desc = if self.spoiler_level == 1 {
                    Self::strip_spoilers(desc)
                } else {
                    desc.clone()
                };

                if !display_desc.is_empty() {
                    content.push(json!({
                        "tag": "details",
                        "content": [
                            { "tag": "summary", "content": "Description" },
                            {
                                "tag": "div",
                                "style": { "fontSize": "0.9em", "marginTop": "4px" },
                                "content": display_desc
                            }
                        ]
                    }));
                }
            }

            let mut info_items = vec![];

            let stats = self.format_stats(char);
            if !stats.is_empty() {
                info_items.push(json!({
                    "tag": "li",
                    "style": { "fontWeight": "bold" },
                    "content": stats
                }));
            }

            if !info_items.is_empty() {
                content.push(json!({
                    "tag": "details",
                    "content": [
                        { "tag": "summary", "content": "Character Information" },
                        {
                            "tag": "ul",
                            "style": { "marginTop": "4px", "paddingLeft": "20px" },
                            "content": info_items
                        }
                    ]
                }));
            }
        }

        json!({
            "type": "structured-content",
            "content": content
        })
    }

    /// Create a Yomitan term entry
    pub fn create_term_entry(
        &self,
        term: &str,
        reading: &str,
        role: &str,
        score: i32,
        content: serde_json::Value,
    ) -> serde_json::Value {
        json!([
            term,
            reading,
            format!("name {}", role),
            "",
            score,
            [content],
            0,
            ""
        ])
    }
}
```

