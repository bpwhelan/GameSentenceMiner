## 7. NAME PARSER (name_parser.rs)

```rust
use std::collections::HashMap;

/// Japanese name parser for reading generation
pub struct NameParser;

impl NameParser {
    /// Check if text contains kanji (Unicode ranges: 0x4E00-0x9FFF, 0x3400-0x4DBF)
    pub fn contains_kanji(text: &str) -> bool {
        text.chars().any(|c| {
            let code = c as u32;
            (0x4E00 <= code && code <= 0x9FFF) || (0x3400 <= code && code <= 0x4DBF)
        })
    }

    /// Split Japanese name by space
    pub fn split_japanese_name(name: &str) -> (Option<String>, Option<String>, bool) {
        if let Some(pos) = name.find(' ') {
            let family = name[..pos].to_string();
            let given = name[pos + 1..].to_string();
            (Some(family), Some(given), true)
        } else {
            (None, None, false)
        }
    }

    /// Convert katakana to hiragana
    pub fn kata_to_hira(text: &str) -> String {
        text.chars().map(|c| {
            let code = c as u32;
            if code >= 0x30A1 && code <= 0x30F6 {
                char::from_u32(code - 0x60).unwrap_or(c)
            } else {
                c
            }
        }).collect()
    }

    /// Convert romanized text to hiragana
    pub fn alphabet_to_kana(input: &str) -> String {
        self.alphabet_to_kana_impl(input)
    }

    fn alphabet_to_kana_impl(input: &str) -> String {
        let text = input.to_lowercase();
        let chars: Vec<char> = text.chars().collect();
        let mut result = String::new();
        let mut i = 0;

        let romaji_map = Self::get_romaji_map();

        while i < chars.len() {
            // Try 3-char sequences first
            if i + 3 <= chars.len() {
                let three_char: String = chars[i..i+3].iter().collect();
                if let Some(kana) = romaji_map.get(three_char.as_str()) {
                    result.push_str(kana);
                    i += 3;
                    continue;
                }
            }

            // Try 2-char sequences
            if i + 2 <= chars.len() {
                let two_char: String = chars[i..i+2].iter().collect();
                if let Some(kana) = romaji_map.get(two_char.as_str()) {
                    result.push_str(kana);
                    i += 2;
                    continue;
                }
            }

            // Try 1-char sequences
            let one_char = chars[i].to_string();
            if let Some(kana) = romaji_map.get(one_char.as_str()) {
                result.push_str(kana);
            } else if one_char == "n" && (i + 1 >= chars.len() || !Self::is_vowel_or_y(chars[i + 1])) {
                result.push('ん');
            } else {
                result.push(chars[i]);
            }
            i += 1;
        }

        result
    }

    fn is_vowel_or_y(c: char) -> bool {
        matches!(c, 'a' | 'i' | 'u' | 'e' | 'o' | 'y')
    }

    fn get_romaji_map() -> HashMap<&'static str, &'static str> {
        let mut map = HashMap::new();

        // 3-char sequences
        map.insert("sha", "しゃ");
        map.insert("shi", "し");
        map.insert("shu", "しゅ");
        map.insert("sho", "しょ");
        map.insert("chi", "ち");
        map.insert("tsu", "つ");
        map.insert("cha", "ちゃ");
        map.insert("chu", "ちゅ");
        map.insert("cho", "ちょ");
        map.insert("nya", "にゃ");
        map.insert("nyu", "にゅ");
        map.insert("nyo", "にょ");
        map.insert("hya", "ひゃ");
        map.insert("hyu", "ひゅ");
        map.insert("hyo", "ひょ");
        map.insert("mya", "みゃ");
        map.insert("myu", "みゅ");
        map.insert("myo", "みょ");
        map.insert("rya", "りゃ");
        map.insert("ryu", "りゅ");
        map.insert("ryo", "りょ");
        map.insert("gya", "ぎゃ");
        map.insert("gyu", "ぎゅ");
        map.insert("gyo", "ぎょ");
        map.insert("bya", "びゃ");
        map.insert("byu", "びゅ");
        map.insert("byo", "びょ");
        map.insert("pya", "ぴゃ");
        map.insert("pyu", "ぴゅ");
        map.insert("pyo", "ぴょ");
        map.insert("kya", "きゃ");
        map.insert("kyu", "きゅ");
        map.insert("kyo", "きょ");
        map.insert("jya", "じゃ");
        map.insert("jyu", "じゅ");
        map.insert("jyo", "じょ");

        // 2-char sequences
        let consonants = vec![
            ("ka", "か"), ("ki", "き"), ("ku", "く"), ("ke", "け"), ("ko", "こ"),
            ("sa", "さ"), ("si", "し"), ("su", "す"), ("se", "せ"), ("so", "そ"),
            ("ta", "た"), ("ti", "ち"), ("tu", "つ"), ("te", "て"), ("to", "と"),
            ("na", "な"), ("ni", "に"), ("nu", "ぬ"), ("ne", "ね"), ("no", "の"),
            ("ha", "は"), ("hi", "ひ"), ("hu", "ふ"), ("fu", "ふ"), ("he", "へ"), ("ho", "ほ"),
            ("ma", "ま"), ("mi", "み"), ("mu", "む"), ("me", "め"), ("mo", "も"),
            ("ra", "ら"), ("ri", "り"), ("ru", "る"), ("re", "れ"), ("ro", "ろ"),
            ("ya", "や"), ("yu", "ゆ"), ("yo", "よ"),
            ("wa", "わ"), ("wi", "ゐ"), ("we", "ゑ"), ("wo", "を"),
            ("ga", "が"), ("gi", "ぎ"), ("gu", "ぐ"), ("ge", "げ"), ("go", "ご"),
            ("za", "ざ"), ("zi", "じ"), ("zu", "ず"), ("ze", "ぜ"), ("zo", "ぞ"),
            ("da", "だ"), ("di", "ぢ"), ("du", "づ"), ("de", "で"), ("do", "ど"),
            ("ba", "ば"), ("bi", "び"), ("bu", "ぶ"), ("be", "べ"), ("bo", "ぼ"),
            ("pa", "ぱ"), ("pi", "ぴ"), ("pu", "ぷ"), ("pe", "ぺ"), ("po", "ぽ"),
            ("ja", "じゃ"), ("ju", "じゅ"), ("jo", "じょ"),
        ];

        for (rom, kan) in consonants {
            map.insert(rom, kan);
        }

        // 1-char sequences
        map.insert("a", "あ");
        map.insert("i", "い");
        map.insert("u", "う");
        map.insert("e", "え");
        map.insert("o", "お");

        map
    }

    /// Generate readings for mixed kanji/kana names
    /// Per-part logic:
    /// - If part has kanji: use romanized reading
    /// - If part is kana: use kana directly (kata→hira only)
    pub fn generate_mixed_readings(
        name_original: &str,
        romanized_name: &str,
    ) -> (String, String, String) {
        // Split Japanese name (Family Given order)
        let (jp_family, jp_given, has_space) = Self::split_japanese_name(name_original);

        if !has_space {
            if Self::contains_kanji(name_original) {
                let full = Self::alphabet_to_kana_impl(romanized_name);
                return (full.clone(), full.clone(), full);
            } else {
                let full = Self::kata_to_hira(name_original);
                return (full.clone(), full.clone(), full);
            }
        }

        // Split romanized (Western order: Given Family)
        let rom_parts: Vec<&str> = romanized_name.splitn(2, ' ').collect();
        let rom_given = rom_parts.get(0).copied().unwrap_or("");
        let rom_family = rom_parts.get(1).copied().unwrap_or("");

        // Determine family reading
        let family_reading = if let Some(ref fam) = jp_family {
            if Self::contains_kanji(fam) {
                Self::alphabet_to_kana_impl(rom_given)
            } else {
                Self::kata_to_hira(fam)
            }
        } else {
            String::new()
        };

        // Determine given reading
        let given_reading = if let Some(ref giv) = jp_given {
            if Self::contains_kanji(giv) {
                Self::alphabet_to_kana_impl(rom_family)
            } else {
                Self::kata_to_hira(giv)
            }
        } else {
            String::new()
        };

        let full_reading = format!("{}{}", family_reading, given_reading);

        (family_reading, given_reading, full_reading)
    }
}
```

