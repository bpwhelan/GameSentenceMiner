## 6. ANILIST API CLIENT (anilist_client.rs)

```rust
use reqwest::Client;
use serde_json::{json, Value};
use crate::models::*;

pub struct AnilistClient {
    client: Client,
}

impl AnilistClient {
    pub fn new() -> Self {
        Self {
            client: Client::new(),
        }
    }

    const API_URL: &'static str = "https://graphql.anilist.co";

    const CHARACTERS_QUERY: &'static str = r#"
    query ($id: Int!, $type: MediaType, $page: Int, $perPage: Int) {
        Media(id: $id, type: $type) {
            id
            title {
                romaji
                english
                native
            }
            characters(page: $page, perPage: $perPage, sort: [ROLE, RELEVANCE, ID]) {
                pageInfo {
                    hasNextPage
                    currentPage
                }
                edges {
                    role
                    node {
                        id
                        name {
                            first
                            last
                            full
                            native
                            alternative
                        }
                        image {
                            large
                            medium
                        }
                        description
                        gender
                        age
                    }
                }
            }
        }
    }
    "#;

    /// Fetch all characters from AniList with pagination
    pub async fn fetch_characters(
        &self,
        media_id: i32,
        media_type: &str,
    ) -> Result<Vec<Character>, String> {
        let mut all_chars = Vec::new();
        let mut page = 1;

        loop {
            let variables = json!({
                "id": media_id,
                "type": media_type.to_uppercase(),
                "page": page,
                "perPage": 25
            });

            let response = self.client
                .post(Self::API_URL)
                .json(&json!({
                    "query": Self::CHARACTERS_QUERY,
                    "variables": variables
                }))
                .send()
                .await
                .map_err(|e| format!("Request failed: {}", e))?;

            if response.status() != 200 {
                return Err(format!("AniList API returned status {}", response.status()));
            }

            let data: Value = response.json().await
                .map_err(|e| format!("Failed to parse JSON: {}", e))?;

            if data["errors"].is_array() {
                return Err(format!("GraphQL error: {:?}", data["errors"]));
            }

            let edges = data["data"]["Media"]["characters"]["edges"]
                .as_array()
                .ok_or("Invalid response format")?;

            for edge in edges {
                if let Some(char) = self.process_character(edge) {
                    all_chars.push(char);
                }
            }

            let has_next = data["data"]["Media"]["characters"]["pageInfo"]["hasNextPage"]
                .as_bool()
                .unwrap_or(false);

            if !has_next {
                break;
            }

            page += 1;
            tokio::time::sleep(tokio::time::Duration::from_millis(300)).await;
        }

        Ok(all_chars)
    }

    /// Process a single character from AniList response
    fn process_character(&self, edge: &Value) -> Option<Character> {
        let node = edge["node"].as_object()?;
        let role_raw = edge["role"].as_str().unwrap_or("BACKGROUND");

        // Map AniList roles to VNDB format
        let role = match role_raw {
            "MAIN" => "main",
            "SUPPORTING" => "primary",
            "BACKGROUND" => "side",
            _ => "side",
        }.to_string();

        let name_data = node.get("name")?;
        let name_full = name_data["full"].as_str().unwrap_or("").to_string();
        let name_native = name_data["native"].as_str().unwrap_or("").to_string();

        let alternatives = name_data["alternative"]
            .as_array()
            .map(|arr| arr.iter().filter_map(|v| v.as_str().map(|s| s.to_string())).collect())
            .unwrap_or_default();

        // Gender mapping
        let sex = node.get("gender")
            .and_then(|g| g.as_str())
            .and_then(|g| match g.to_lowercase().chars().next() {
                Some('m') => Some("m"),
                Some('f') => Some("f"),
                _ => None,
            })
            .map(|s| s.to_string());

        // Birthday
        let birthday = node.get("dateOfBirth")
            .and_then(|dob| {
                let month = dob["month"].as_u64()? as u32;
                let day = dob["day"].as_u64()? as u32;
                Some(vec![month, day])
            });

        // Image URL
        let image_url = node.get("image")
            .and_then(|img| img["large"].as_str())
            .map(|s| s.to_string());

        Some(Character {
            id: node.get("id").and_then(|v| v.as_u64()).unwrap_or(0).to_string(),
            name: name_full,
            name_original: name_native,
            role,
            sex,
            age: node.get("age").and_then(|v| v.as_u64()).map(|a| a.to_string()),
            height: None,
            weight: None,
            blood_type: node.get("bloodType").and_then(|v| v.as_str()).map(|s| s.to_string()),
            birthday,
            description: node.get("description").and_then(|v| v.as_str()).map(|s| s.to_string()),
            aliases: alternatives,
            personality: Vec::new(),
            roles: Vec::new(),
            engages_in: Vec::new(),
            subject_of: Vec::new(),
            image_url,
            image_base64: None,
        })
    }

    /// Download and encode image as base64
    pub async fn fetch_image_as_base64(&self, url: &str) -> Option<String> {
        let response = self.client
            .get(url)
            .send()
            .await
            .ok()?;

        if response.status() != 200 {
            return None;
        }

        let bytes = response.bytes().await.ok()?;
        let b64 = base64::engine::general_purpose::STANDARD.encode(&bytes);
        Some(format!("data:image/jpeg;base64,{}", b64))
    }
}
```

