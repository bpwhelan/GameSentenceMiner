## 9. IMAGE HANDLER (image_handler.rs)

```rust
use base64::engine::general_purpose::STANDARD;
use base64::Engine;

pub struct ImageHandler;

impl ImageHandler {
    /// Decode base64 image and return (filename, bytes)
    pub fn decode_image(base64_data: &str, char_id: &str) -> (String, Vec<u8>) {
        let (ext, data) = if let Some(pos) = base64_data.find(',') {
            let header = &base64_data[..pos];
            let data = &base64_data[pos + 1..];
            
            let ext = if header.contains("png") {
                "png"
            } else if header.contains("gif") {
                "gif"
            } else if header.contains("webp") {
                "webp"
            } else {
                "jpg"
            };
            
            (ext, data)
        } else {
            ("jpg", base64_data)
        };

        let image_bytes = STANDARD.decode(data).unwrap_or_default();
        let filename = format!("c{}.{}", char_id, ext);

        (filename, image_bytes)
    }
}
```

