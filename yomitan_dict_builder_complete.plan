## 10. DICT BUILDER (dict_builder.rs)

```rust
use std::io::Write;
use zip::ZipWriter;
use serde_json::json;
use crate::models::*;
use crate::name_parser::NameParser;
use crate::content_builder::ContentBuilder;
use crate::image_handler::ImageHandler;

pub struct DictBuilder {
    entries: Vec<serde_json::Value>,
    images: Vec<(String, Vec<u8>)>,
    spoiler_level: u8,
    revision: String,
}

impl DictBuilder {
    pub fn new(spoiler_level: u8) -> Self {
        let revision = rand::random::<u32>().to_string();
        Self {
            entries: Vec::new(),
            images: Vec::new(),
            spoiler_level,
            revision,
        }
    }

    /// Add a character and create term entries
    pub fn add_character(&mut self, char: &Character, game_title: &str) {
        let name_original = &char.name_original;
        if name_original.is_empty() {
            return;
        }

        // Generate readings
        let (family_reading, given_reading, full_reading) = NameParser::generate_mixed_readings(
            name_original,
            &char.name,
        );

        let content_builder = ContentBuilder::new(self.spoiler_level);
        let score = match char.role.as_str() {
            "main" => 100,
            "primary" => 75,
            "side" => 50,
            _ => 25,
        };

        // Handle image
        let image_path = if let Some(ref img_base64) = char.image_base64 {
            let (filename, image_bytes) = ImageHandler::decode_image(img_base64, &char.id);
            let path = format!("img/{}", filename);
            self.images.push((filename, image_bytes));
            Some(path)
        } else {
            None
        };

        let content = content_builder.build_content(char, image_path.as_deref(), game_title);

        // Add entries for different name variants
        let mut added_terms = std::collections::HashSet::new();

        // Full name with space
        if !name_original.is_empty() && added_terms.insert(name_original.clone()) {
            let entry = content_builder.create_term_entry(
                name_original,
                &full_reading,
                &char.role,
                score,
                content.clone(),
            );
            self.entries.push(entry);
        }

        // Combined without space
        let combined = name_original.replace(" ", "");
        if !combined.is_empty() && added_terms.insert(combined.clone()) {
            let entry = content_builder.create_term_entry(
                &combined,
                &full_reading,
                &char.role,
                score,
                content.clone(),
            );
            self.entries.push(entry);
        }

        // Family name only
        if let Some(pos) = name_original.find(' ') {
            let family = &name_original[..pos];
            if !family.is_empty() && added_terms.insert(family.to_string()) {
                let entry = content_builder.create_term_entry(
                    family,
                    &family_reading,
                    &char.role,
                    score,
                    content.clone(),
                );
                self.entries.push(entry);
            }

            // Given name only
            let given = &name_original[pos + 1..];
            if !given.is_empty() && added_terms.insert(given.to_string()) {
                let entry = content_builder.create_term_entry(
                    given,
                    &given_reading,
                    &char.role,
                    score,
                    content.clone(),
                );
                self.entries.push(entry);
            }
        }
    }

    /// Create index.json
    fn create_index(&self) -> serde_json::Value {
        json!({
            "title": "GSM Character Dictionary",
            "revision": &self.revision,
            "format": 3,
            "author": "GameSentenceMiner",
            "description": "Character names from visual novels"
        })
    }

    /// Create tag_bank_1.json
    fn create_tags(&self) -> serde_json::Value {
        json!([
            ["name", "partOfSpeech", 0, "Character name", 0],
            ["main", "name", 0, "Protagonist", 0],
            ["primary", "name", 0, "Main character", 0],
            ["side", "name", 0, "Side character", 0],
            ["appears", "name", 0, "Minor appearance", 0]
        ])
    }

    /// Export as ZIP bytes
    pub fn export_bytes(&self) -> Vec<u8> {
        let mut buffer = Vec::new();
        let mut zip = ZipWriter::new(&mut buffer);

        // index.json
        zip.start_file("index.json", Default::default()).ok();
        let index = serde_json::to_string_pretty(&self.create_index()).unwrap();
        zip.write_all(index.as_bytes()).ok();

        // tag_bank_1.json
        zip.start_file("tag_bank_1.json", Default::default()).ok();
        let tags = serde_json::to_string(&self.create_tags()).unwrap();
        zip.write_all(tags.as_bytes()).ok();

        // term_bank_N.json
        let entries_per_bank = 10000;
        for (i, chunk) in self.entries.chunks(entries_per_bank).enumerate() {
            let filename = format!("term_bank_{}.json", i + 1);
            zip.start_file(&filename, Default::default()).ok();
            let data = serde_json::to_string(chunk).unwrap();
            zip.write_all(data.as_bytes()).ok();
        }

        // Images
        for (filename, bytes) in &self.images {
            zip.start_file(format!("img/{}", filename), Default::default()).ok();
            zip.write_all(bytes).ok();
        }

        zip.finish().ok();
        buffer
    }
}
```

