    // Casual/Friendly
    ("君", "くん"),
    ("くん", "くん"),
    ("ちゃん", "ちゃん"),
    ("たん", "たん"),
    ("坊", "ぼう"),
    // Old-fashioned/Archaic
    ("殿", "どの"),
    ("博士", "はかせ"),
