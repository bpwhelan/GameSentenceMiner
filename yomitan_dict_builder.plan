fn test_normalize_id_uppercase_v() {
assert_eq!(VndbClient::normalize_id("V17"), "v17");
⋮----
fn test_normalize_id_with_whitespace() {
assert_eq!(VndbClient::normalize_id("  v17  "), "v17");
⋮----
fn test_normalize_id_large_number() {
assert_eq!(VndbClient::normalize_id("58641"), "v58641");
